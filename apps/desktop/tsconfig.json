{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "../..",
    "outDir": "dist/types",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node", "vitest", "react", "react-dom"]
  },
  "include": [
    "electron.vite.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "../../packages/core/src/**/*.ts",
    "../../packages/db/src/**/*.ts"
  ]
}
