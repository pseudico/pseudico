{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@local-work-os/core": ["./packages/core/src/index.ts"],
      "@local-work-os/db": ["./packages/db/src/index.ts"],
      "@local-work-os/features": ["./packages/features/src/index.ts"],
      "@local-work-os/ui": ["./packages/ui/src/index.ts"],
      "@local-work-os/test-utils": ["./packages/test-utils/src/index.ts"]
    }
  }
}
